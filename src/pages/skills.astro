---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactPanel from '@/components/ContactPanel.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import SkillCard from '@/components/SkillCard.astro';
import { skills } from '@/data/profile';
---

<BaseLayout
  title="Skills | Wissal Saidi"
  description="Explore Wissal Saidi's frontend development, web development, and software fundamentals for remote junior developer roles."
>
  <section class="page-hero">
    <p class="eyebrow">Skills</p>
    <h1>Practical development skills with an elegant eye.</h1>
    <p>Frontend implementation, web development, and software fundamentals organized around clean, useful digital experiences.</p>
  </section>
  <section class="content-band">
    <SectionHeader title="What I can contribute remotely" text="A focused toolkit for building responsive web products and reliable software foundations." />
    <div class="card-grid three">
      {skills.map((skill) => <SkillCard {...skill} />)}
    </div>
  </section>
  <ContactPanel />
</BaseLayout>
