---
import { profile } from '@/data/profile';

const stats = [
  ['Based in', profile.location],
  ['Focus', profile.focus],
  ['Availability', profile.availability],
  ['Status', profile.status],
];
---

<section class="stats-grid" aria-label="Key portfolio information">
  {
    stats.map(([label, value]) => (
      <article>
        <span>{label}</span>
        <strong>{value}</strong>
      </article>
    ))
  }
</section>
