---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { profile } from '@/data/profile';
---

<BaseLayout
  title="Contact | Wissal Saidi"
  description="Contact Wissal Saidi for internships, collaborations, junior software roles, and web development projects."
>
  <section class="page-hero contact-page">
    <p class="eyebrow">Contact</p>
    <h1>Let's build something together.</h1>
    <p>
      Have an internship, collaboration, or exciting project in mind? Let's connect and create
      innovative digital solutions together.
    </p>
    <div class="hero-actions">
      <a class="button primary" href={`mailto:${profile.email}`}>{profile.email}</a>
      {profile.socials.map((social) => (
        <a class="button ghost" href={social.href} target="_blank" rel="noreferrer">{social.label}</a>
      ))}
    </div>
  </section>
</BaseLayout>
