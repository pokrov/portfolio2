---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactPanel from '@/components/ContactPanel.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Stats from '@/components/Stats.astro';
import { profile } from '@/data/profile';
---

<BaseLayout
  title="About Wissal Saidi | Junior Frontend Developer"
  description="Learn about Wissal Saidi, a junior frontend developer based in Morocco, focused on responsive interfaces and reliable remote collaboration."
>
  <section class="page-hero">
    <p class="eyebrow">About</p>
    <h1>A developer who works with clarity, discipline, and attention to detail.</h1>
    <p>
      Wissal brings focused frontend skills, practical web experience, and a remote-ready mindset to modern teams.
    </p>
  </section>
  <Stats />
  <section class="content-band">
    <div class="split-layout">
      <SectionHeader title="Professional, practical, and ready to contribute." />
      <div class="prose">
        {profile.about.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>
  <ContactPanel />
</BaseLayout>
