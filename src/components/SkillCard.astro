---
import Badge from './Badge.astro';

interface Props {
  title: string;
  description: string;
  technologies: string[];
}

const { title, description, technologies } = Astro.props;
---

<article class="soft-card skill-card">
  <div class="card-icon" aria-hidden="true">&lt;/&gt;</div>
  <h3>{title}</h3>
  <p>{description}</p>
  <div class="tag-list" aria-label={`${title} technologies`}>
    {technologies.map((tech) => <Badge label={tech} />)}
  </div>
</article>

