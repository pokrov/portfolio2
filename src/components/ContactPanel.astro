---
import { profile } from '@/data/profile';
---

<section class="contact-panel" aria-labelledby="contact-title">
  <div>
    <p class="eyebrow">Contact</p>
    <h2 id="contact-title">Let's build something together.</h2>
    <p>
      Have an internship, collaboration, or exciting project in mind? Let's connect and create
      innovative digital solutions together.
    </p>
  </div>
  <div class="contact-actions">
    <a class="button primary" href={`mailto:${profile.email}`}>Email Wissal</a>
    <a class="button ghost" href="/resume/">View Resume</a>
  </div>
</section>

